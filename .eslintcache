_sections\">\r\n                    <section>\r\n                        <h1>2020</h1>\r\n                        <a className=\"active\"><SportsEsportsIcon /> My first s&box project</a>\r\n                        <a><MenuBookIcon /> Watch Dogs Legion review</a>\r\n                        <a><CodeIcon /> ReactJS and Firebase</a>\r\n                        <a><CodeIcon /> Food delivery</a>\r\n                    </section>\r\n                    <section>\r\n                        <h1>2017</h1>\r\n                        <a><SportsEsportsIcon /> My first game jam !</a>\r\n                    </section>\r\n                    <div className=\"blog__sections-medias\">\r\n                        <a href=\"https://github.com/suiramdev\"><GitHub /></a>\r\n                        <a href=\"https://twitter.com/suiramdev\"><Twitter /></a>\r\n                        <a href=\"https://suiramdev.itch.io\"><VideogameAsset /></a>\r\n                    </div>\r\n                </div>\r\n                <div className=\"blog__content\">\r\n                    <p>Biography\r\n                    Born in 2002, I 'm passionate in game developement since 4 years… I started developing games on Unity for my own and i'\r\n                    m now looking to turn this passion into my real Job.I already made some games, websites and mods that you can have a look on my website.\r\n\r\n                    My knowledges </p>\r\n                </div>\r\n            </div>\r\n        )\r\n    }\r\n}","F:\\Documents\\Projets\\Web\\suiramdev\\src\\index.js",[],{"ruleId":"28","severity":1,"message":"29","line":3,"column":10,"nodeType":"30","messageId":"31","endLine":3,"endColumn":16},{"ruleId":"28","severity":1,"message":"32","line":8,"column":10,"nodeType":"30","messageId":"31","endLine":8,"endColumn":16},{"ruleId":"28","severity":1,"message":"33","line":9,"column":18,"nodeType":"30","messageId":"31","endLine":9,"endColumn":26},{"ruleId":"34","severity":1,"message":"35","line":15,"column":17,