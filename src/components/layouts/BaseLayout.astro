---
import "../../styles/base.css";
import Navbar from "../Navbar.astro";

interface SEO {
    title?: string;
    description?: string;
    canonicalURL?: string;
}

interface Article {
    published_time?: string;
    author?: string;
}

interface OG {
    title?: string;
    description?: string;
    type?: string;
    url?: string;
    image?: string;
    article?: Article;
}

interface Props {
    SEO?: SEO;
    OG?: OG;
}

const { SEO, OG } = Astro.props;

// Default OG image URL
const OGimage = new URL("/api/og.png", import.meta.env.SITE);
OGimage.searchParams.append("title", "suiramdev's blog");
OGimage.searchParams.append("description", "suiramdev's blog");
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, shrink-to-fit=no"
        />
        <meta name="generator" content={Astro.generator} />
        <title>{SEO?.title ?? "suiramdev's blog"}</title>
        <meta
            name="description"
            content={SEO?.description ??
                "Here, I share my thoughts, reviews, projects, and glimpses of my life."}
        />
        <link
            rel="canonical"
            href={SEO?.canonicalURL ?? import.meta.env.SITE}
        />
        <meta property="og:title" content={OG?.title} />
        <meta property="og:description" content={OG?.description} />
        <meta property="og:type" content={OG?.type ?? "website"} />
        <meta property="og:url" content={OG?.url ?? import.meta.env.SITE} />
        <meta
            property="article:published_time"
            content={OG?.article?.published_time}
        />
        <meta property="article:author" content={OG?.article?.author} />
        <meta property="og:image" content={OG?.image ?? OGimage} />
    </head>
    <body class="pt-8">
        <Navbar />
        <slot />
    </body>
</html>
